# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://tidebook:changeme@localhost:5432/tidebook"
# Test database (used in integration tests — separate from production)
DATABASE_URL_TEST="postgresql://tidebook:changeme@localhost:5432/tidebook_test"

# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV="development"         # development | production | test
PORT=4000
API_BASE_URL="http://localhost:4000"
WEB_BASE_URL="http://localhost:3000"
# Allowed CORS origins (comma-separated)
CORS_ORIGINS="http://localhost:3000"

# ─── Security & Encryption ───────────────────────────────────────────────────
# 32-byte AES-256 key for PII field encryption. Generate with:
#   openssl rand -hex 32
PII_ENCRYPTION_KEY="REPLACE_WITH_64_HEX_CHARS_32_BYTES"
# JWT secrets — generate with: openssl rand -base64 64
JWT_ACCESS_SECRET="REPLACE_WITH_LONG_RANDOM_SECRET"
JWT_REFRESH_SECRET="REPLACE_WITH_DIFFERENT_LONG_RANDOM_SECRET"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
# Bcrypt cost factor (minimum 12)
BCRYPT_ROUNDS=12

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_SECURE=false              # true for port 465
SMTP_USER="education@seattleaquarium.org"
SMTP_PASS="REPLACE_WITH_SMTP_PASSWORD"
EMAIL_FROM="Seattle Aquarium Education <education@seattleaquarium.org>"
# DKIM signing (generate key pair with: openssl genrsa -out dkim_private.pem 2048)
DKIM_DOMAIN="seattleaquarium.org"
DKIM_SELECTOR="education"
# Paste the RSA private key with literal \n for newlines, or use a file path
DKIM_PRIVATE_KEY="REPLACE_WITH_DKIM_PRIVATE_KEY_AS_SINGLE_LINE"

# ─── File Storage ────────────────────────────────────────────────────────────
# LOCAL: absolute path to store uploaded scholarship documents (outside web root)
UPLOAD_DIR="/var/tidebook/uploads"
# S3-compatible storage (optional — leave blank to use local filesystem)
S3_ENDPOINT=""
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# ─── ACME Integration ────────────────────────────────────────────────────────
ACME_API_URL="https://acme.seattleaquarium.org/api/v1"
ACME_API_KEY="REPLACE_WITH_ACME_API_KEY"
# Set to "true" to use the mock ACME adapter (for development/test)
ACME_USE_MOCK=true

# ─── Rate Limiting ───────────────────────────────────────────────────────────
# Uses in-memory store by default. Set REDIS_URL to use Redis.
REDIS_URL=""
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_PUBLIC_MAX=10
RATE_LIMIT_AUTH_MAX=5

# ─── Seed / First-Run ────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL="admin@seattleaquarium.org"
SEED_ADMIN_PASSWORD="REPLACE_WITH_STRONG_INITIAL_PASSWORD"

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL="info"               # error | warn | info | debug
SLOW_QUERY_THRESHOLD_MS=500
